(*
 * Definitions to lex and parse S-expressions, and convert them to Dafny's AST.
 *)

open preamble
open result_monadTheory
open dafny_astTheory
open mlintTheory (* fromNatString *)

(* FIXME Properly escape characters
 *
 * Unsure whether we correctly deal with the escaping behavior from the string
 * generated by Dafny.
 *)

(* TODO Address character set support
 * 
 * Dafny supports richer character sets; unclear how that is/should be handled.
 *)
     
(* Lexing *)
Datatype:
  token = OPEN | CLOSE | STRTOK string
End

Definition read_quoted_aux_def:
  read_quoted_aux [] acc =
    fail "read_quoted_aux: Missing closing quotes" ∧
  read_quoted_aux (#"\""::rest) acc =
    return ((REVERSE acc), rest) ∧
  read_quoted_aux (#"\\"::#"\""::rest) acc =
    read_quoted_aux rest (#"\""::acc) ∧
  (* read_quoted_aux (#"\\"::#"\\"::rest) acc = *)
  (*   read_quoted_aux rest (#"\\"::acc) ∧ *)
  read_quoted_aux (c::cs) acc =
    read_quoted_aux cs (c::acc)
End
Definition read_quoted_def:
  read_quoted (cs: string) =
    read_quoted_aux cs []
End

Definition read_atom_aux_def:
  read_atom_aux [] acc =
    ((REVERSE acc), []) ∧
  read_atom_aux (c::cs) acc =
    if MEM c ") \t\n" then ((REVERSE acc), (c::cs))
    else read_atom_aux cs (c::acc)
End
Definition read_atom_def:
  read_atom cs =
    read_atom_aux cs []
End

Definition lex_aux_def:
  lex_aux [] acc =
    return acc ∧
  lex_aux (c::cs) acc =
    if MEM c " \t\n" then lex_aux cs acc
    else if c = #"(" then lex_aux cs (OPEN::acc)
    else if c = #")" then lex_aux cs (CLOSE::acc)
    else if c = #"\"" then
      do
        (s, rest) <- read_quoted cs;
        lex_aux rest ((STRTOK s)::acc)
      od
    else
      case read_atom (c::cs) of
      | (s, rest) =>
          lex_aux rest ((STRTOK s)::acc)
Termination
  cheat
End
Definition lex_def:
  lex cs =
    lex_aux cs []
End

(* Parsing *)
Datatype:
  sexp = Atom string | Expr (sexp list)
End

Definition parse_aux_def:
  parse_aux ((STRTOK s)::rest) acc =
    parse_aux rest ((Atom s)::acc) ∧
  parse_aux (CLOSE::rest) acc =
    do
      (e, rest) <- (parse_aux rest []);
      parse_aux rest (e::acc)
    od ∧
  parse_aux (OPEN::rest) acc =  (* Need to consume OPEN *)
    return (Expr (acc), rest) ∧
  parse_aux [] acc =
    return (Expr (acc), [])
Termination
  cheat
End

Definition parse_def:
  parse [(STRTOK s)] =
    return (Atom s) ∧
  parse (CLOSE::rest) =
    do
      (e, rest) <- (parse_aux rest []);
      if rest = [] then
        return e
      else fail ("parse: Tokens still remaining after parsing Expr")
    od ∧
  parse ts =
    fail ("parse: First token was not STRTOK or CLOSE")
End

(* Converting S-expressions to Dafny's AST *)

(* Helpers *)

Definition unexpected_atom_error_def:
  unexpected_atom_error expected received =
    ("Expected Atom to contain " ++ expected ++ ", but received " ++ received)
End

Definition atom_to_string_def:
  atom_to_string (Atom s) = return s ∧
  atom_to_string _ = fail "atom_to_string: Not an Atom"
End

Definition atom_to_bool_def:
  atom_to_bool (Atom s) =
    (if s = "True" then return T
     else if s = "False" then return F
     else fail ("atom_to_bool: " ++
                (unexpected_atom_error "True or False" s))) ∧
  atom_to_bool _ = fail "atom_to_bool: Not an Atom"
End

Definition atom_to_num_def:
  atom_to_num (Atom s) =
  (case fromNatString (implode s) of
   | SOME n => return n
   | NONE => fail ("atom_to_num: Failed to convert " ++ s ++ " into num")) ∧
  atom_to_num _ = fail "atom_to_num: Not an Atom"
End

Definition mmap_expr_def:
  result_mmap_expr f (Expr e) = result_mmap f e ∧
  result_mmap_expr _ _ = fail "mmap_expr: Can only be applied to Expr"
End

Definition check_def:
  check se sym =
    case se of
    | Expr [(Atom s)] =>
        if s = sym then
          return ()
        else
          fail ("check: " ++ (unexpected_atom_error sym s))
    | _ =>
        fail "check: S-expression had incorrect form"
End

Definition check_and_apply_1_def:
  check_and_apply_1 se sym f =
    case se of
    | Expr [(Atom s); x] =>
        if s = sym then
          do
            x' <- f x;
            return x'
          od
        else
          fail ("check_and_apply_1: " ++ (unexpected_atom_error sym s))
    | _ =>
        fail "check_and_apply_1: S-expression had incorrect form"
End

Definition check_and_apply_2_def:
  check_and_apply_2 se sym f1 f2 =
    case se of
    | Expr [(Atom s); x1; x2] =>
        if s = sym then
          do
            x1' <- f1 x1;
            x2' <- f2 x2;
            return (x1', x2')
          od
        else
          fail ("check_and_apply_2: " ++ (unexpected_atom_error sym s))
    | _ =>
        fail "check_and_apply_2: S-expression had incorrect form"
End

Definition check_and_apply_3_def:
  check_and_apply_3 se sym f1 f2 f3 =
    case se of
    | Expr [(Atom s); x1; x2; x3] =>
        if s = sym then
          do
            x1' <- f1 x1;
            x2' <- f2 x2;
            x3' <- f3 x3;
            return (x1', x2', x3')
          od
        else
          fail ("check_and_apply_3: " ++ (unexpected_atom_error sym s))
    | _ =>
        fail "check_and_apply_3: S-expression had incorrect form"
End

Definition check_and_apply_4_def:
  check_and_apply_4 se sym f1 f2 f3 f4 =
    case se of
    | Expr [(Atom s); x1; x2; x3; x4] =>
        if s = sym then
          do
            x1' <- f1 x1;
            x2' <- f2 x2;
            x3' <- f3 x3;
            x4' <- f4 x4;
            return (x1', x2', x3', x4')
          od
        else
          fail ("check_and_apply_4: " ++ (unexpected_atom_error sym s))
    | _ =>
        fail "check_and_apply_4: S-expression had incorrect form"
End

(* Conversion *)

Definition sexp_to_name_def:
  sexp_to_name se =
  do
    s <- check_and_apply_1 se "Name.Name" atom_to_string;
    return (Name s)
  od
End
val test = EVAL “sexp_to_name (Expr [Atom "Name.Name"; Atom "T0"])”;
val test = EVAL “sexp_to_name (Expr [Atom "Name.N ame"; Atom "T0"])”;
val test = EVAL “sexp_to_name (Expr [Atom "Name.Name"])”;

Definition sexp_to_ident_def:
  sexp_to_ident se =
    do
      n <- check_and_apply_1 se "Ident.Ident" sexp_to_name;
      return (Ident n)
    od
End
val test = EVAL “sexp_to_ident (Expr [Atom "Ident.Ident"; Expr [Atom "Name.Name";Atom "T0"]])”;

Definition sexp_to_attribute_def:
  sexp_to_attribute se =
    do
      (s, args) <- check_and_apply_2 se "Attribute.Attribute" atom_to_string
                                     (result_mmap_expr atom_to_string);
      return (Attribute s args)
    od
End
val test = EVAL “sexp_to_attribute (Expr [Atom "Attribute.Attribute"; Atom "axiom"; Expr []])”;

Definition sexp_to_primitive_def:
  sexp_to_primitive se =
    do
      do check se "Primitive.Int"; return Int od ++
      do check se "Primitive.Real"; return Real od ++
      do check se "Primitive.String"; return String od ++
      do check se "Primitive.Bool"; return Bool od ++
      do check se "Primitive.Char"; return Char od ++
      fail "sexp_to_primitive: Unexpected S-expression"
    od
End

Definition sexp_to_collKind_def:
  sexp_to_collKind se =
    do
      do check se "CollKind.Seq"; return CollKind_Seq od ++
      do check se "CollKind.Array"; return CollKind_Array od ++
      do check se "CollKind.Map"; return CollKind_Map od ++
      fail "sexp_to_collKind: Unexpected S-expression"
    od
End
  
Definition sexp_to_typeArgBound_def:
  sexp_to_typeArgBound se =
    do
      do
        check se "TypeArgBound.SupportsEquality";
        return SupportsEquality
      od ++
      do
        check se "TypeArgBound.SupportsDefault";
        return SupportsDefault
      od ++
      fail "sexp_to_typeArgBound: Unexpected S-expression"
    od
End

Definition sexp_to_typeArgDecl_def:
  sexp_to_typeArgDecl se =
    do
      (n, bounds) <- check_and_apply_2 se "TypeArgDecl.TypeArgDecl"
                                       sexp_to_ident
                                       (result_mmap_expr sexp_to_typeArgBound);
      return (TypeArgDecl n bounds)
    od
End

Definition sexp_to_newtypeRange_def:
  sexp_to_newtypeRange se =
    do
      do check se "NewtypeRange.U8"; return U8 od ++
      do check se "NewtypeRange.I8"; return I8 od ++
      do check se "NewtypeRange.U16"; return U16 od ++
      do check se "NewtypeRange.I16"; return I16 od ++
      do check se "NewtypeRange.U32"; return U32 od ++
      do check se "NewtypeRange.I32"; return I32 od ++
      do check se "NewtypeRange.U64"; return U64 od ++
      do check se "NewtypeRange.I64"; return I64 od ++
      do check se "NewtypeRange.U128"; return U128 od ++
      do check se "NewtypeRange.I128"; return I128 od ++
      do check se "NewtypeRange.BigInt"; return BigInt od ++
      do check se "NewtypeRange.NoRange"; return NoRange od ++
      fail "sexp_to_newtypeRange: Unexpected S-expression"
    od
End

Definition sexp_to_unaryOp_def:
  sexp_to_unaryOp se =
    do
      do check se "UnaryOp.Not"; return Not od ++
      do check se "UnaryOp.BitwiseNot"; return BitwiseNot od ++
      do check se "UnaryOp.Cardinality"; return Cardinality od ++
      fail "sexp_to_unaryOp: Unexpected S-expression"
    od
End

Definition sexp_to_binOp_def:
  sexp_to_binOp se =
    do
      do
        (ref, nul) <- check_and_apply_2 se "BinOp.Eq"
                                        atom_to_bool atom_to_bool;
        return (Eq ref nul)
      od ++
      do check se "BinOp.Div"; return Div od ++
      do check se "BinOp.EuclidianDiv"; return EuclidianDiv od ++
      do check se "BinOp.Mod"; return Mod od ++
      do check se "BinOp.EuclidianMod"; return EuclidianMod od ++
      do check se "BinOp.Lt"; return Lt od ++
      do check se "BinOp.LtChar"; return LtChar od ++
      do check se "BinOp.Plus"; return Plus od ++
      do check se "BinOp.Minus"; return Minus od ++
      do check se "BinOp.Times"; return Times od ++
      do check se "BinOp.BitwiseAnd"; return BitwiseAnd od ++
      do check se "BinOp.BitwiseOr"; return BitwiseOr od ++
      do check se "BinOp.BitwiseXor"; return BitwiseXor od ++
      do check se "BinOp.BitwiseShiftRight"; return BitwiseShiftRight od ++
      do check se "BinOp.BitwiseShiftLeft"; return BitwiseShiftLeft od ++
      do check se "BinOp.And"; return And od ++
      do check se "BinOp.Or"; return Or od ++
      do check se "BinOp.In"; return In od ++
      do check se "BinOp.SeqProperPrefix"; return SeqProperPrefix od ++
      do check se "BinOp.SeqPrefix"; return SeqPrefix od ++
      do check se "BinOp.SetMerge"; return SetMerge od ++
      do check se "BinOp.SetSubtraction"; return SetSubtraction od ++
      do check se "BinOp.SetIntersection"; return SetIntersection od ++
      do check se "BinOp.Subset"; return Subset od ++
      do check se "BinOp.ProperSubset"; return ProperSubset od ++
      do check se "BinOp.SetDisjoint"; return SetDisjoint od ++
      do check se "BinOp.MapMerge"; return MapMerge od ++
      do check se "BinOp.MapSubtraction"; return MapSubtraction od ++
      do check se "BinOp.MultisetMerge"; return MultisetMerge od ++
      do
        check se "BinOp.MultisetSubtraction";
        return MultisetSubtraction
      od ++
      do
        check se "BinOp.MultisetIntersection";
        return MultisetIntersection
      od ++
      do check se "BinOp.Submultiset"; return Submultiset od ++
      do check se "BinOp.ProperSubmultiset"; return ProperSubmultiset od ++
      do check se "BinOp.MultisetDisjoint"; return MultisetDisjoint od ++
      do check se "BinOp.Concat"; return Concat od ++
      do
        s <- check_and_apply_1 se "BinOp.ConcatPassthrough" atom_to_string;
        return (BinOp_Passthrough s)
      od ++
      fail "sexp_to_binOp: Unexpected S-expression"
    od
End

Definition sexp_to_datatypeType_def:
  sexp_to_datatypeType se =
    do
      (p, attrs) <- check_and_apply_2 se "DatatypeType.DatatypeType"
                                      (result_mmap_expr sexp_to_ident)
                                      (result_mmap_expr sexp_to_attribute);
      return (DatatypeType p attrs)
    od
End

(* Defines the mutually recursive functions sexp_resolvedType and
 * sexp_to_type *)
Definition sexp_to_type_def:
  sexp_to_type se =
    do
      (is, ts, rs) <- check_and_apply_3 se "Type.Path"
                                        (result_mmap_expr sexp_to_ident)
                                        (result_mmap_expr sexp_to_type)
                                        sexp_to_resolvedType;
      return (Path is ts rs)
    od ++
    do
      t <- check_and_apply_1 se "Type.Nullable" sexp_to_type;
      return (Nullable t)
    od ++
    do
      ts <- check_and_apply_1 se "Type.Tuple"
                              (result_mmap_expr sexp_to_type);
      return (Tuple ts)
    od ++
    do
      (e, d) <- check_and_apply_2 se "Type.Array" sexp_to_type atom_to_num;
      return (Array e d)
    od
  ∧
  sexp_to_resolvedType se =
    do
      dt <- check_and_apply_1 se "ResolvedType.Datatype"
                              sexp_to_datatypeType;
      return (ResolvedType_Datatype dt)
    od ++
    do
      (p, attrs) <- check_and_apply_2 se "ResolvedType.Trait"
                                      (result_mmap_expr sexp_to_ident)
                                      (result_mmap_expr sexp_to_attribute);
      return (ResolvedType_Trait p attrs)
    od ++
    do
      (b, r, e, attrs) <- check_and_apply_4 se "ResovledType.Newtype"
                                            sexp_to_type
                                            sexp_to_newtypeRange
                                            atom_to_bool
                                            (result_mmap_expr
                                             sexp_to_attribute);
      return (ResolvedType_Newtype b r e attrs)
    od ++
    fail "sexp_to_resolvedType: Unexpected S-expression"
Termination
  cheat
End

